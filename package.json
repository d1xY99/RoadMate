{
  "name": "roadmate",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@biomejs/biome": "^2.4.8"
    }
  },
  "packageManager": "bun@1.3.13",
  "overrides": {
    "@sinclair/typebox": "^0.34.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev:backend": "cd packages/backend && bun run dev",
    "dev:mobile": "cd packages/mobile && bun run start",
    "up": "cd packages/backend && bun run docker:up",
    "down": "cd packages/backend && bun run docker:down",
    "db:migrate": "cd packages/backend && bun run db:migrate",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "turbo": "^2.8.12",
    "typescript": "~5.7.2"
  }
}
