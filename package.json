{
  "name": "roadmate",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@biomejs/biome": "^2.4.8"
    }
  },
  "packageManager": "bun@1.3.13",
  "overrides": {
    "@sinclair/typebox": "^0.34.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev:web": "cd packages/web && bun run dev",
    "dev:backend": "cd packages/backend && bun run dev",
    "dev:mobile": "cd packages/mobile && bun run start",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:migrate": "dbmate --migrations-dir ./packages/backend/migrations --no-dump-schema --url 'postgresql://postgres:postgres@127.0.0.1:54422/postgres?sslmode=disable' up",
    "db:rollback": "dbmate --migrations-dir ./packages/backend/migrations --no-dump-schema --url 'postgresql://postgres:postgres@127.0.0.1:54422/postgres?sslmode=disable' down",
    "db:status": "dbmate --migrations-dir ./packages/backend/migrations --url 'postgresql://postgres:postgres@127.0.0.1:54422/postgres?sslmode=disable' status",
    "db:new": "dbmate --migrations-dir ./packages/backend/migrations new",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "dbmate": "^2.27.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "supabase": "^2.102.0",
    "turbo": "^2.8.12",
    "typescript": "~5.7.2"
  }
}
