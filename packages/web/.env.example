# Copy to .env (gitignored). Vite exposes only VITE_-prefixed vars to the client.
#
# LOCAL DEV → point at the local Supabase stack (run `bun run db:start`, it
# prints the API URL + publishable key). Defaults below match supabase/config.toml:
VITE_SUPABASE_URL=http://127.0.0.1:54421
VITE_SUPABASE_ANON_KEY=sb_publishable_...local-key-from-db:start...
#
# PRODUCTION → do NOT put cloud keys here. Set them as env vars in Netlify:
#   VITE_SUPABASE_URL      = https://ffqkwegpdtriypbumfss.supabase.co
#   VITE_SUPABASE_ANON_KEY = <cloud publishable key>
