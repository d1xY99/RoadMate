{
  "name": "@roadmate/backend",
  "version": "0.1.0",
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build ./src/index.ts --target bun --outdir dist",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "fix": "biome check --write .",
    "test": "bun test",
    "db:migrate": "bunx dbmate --migrations-dir ./migrations --url $DB_URL up",
    "db:rollback": "bunx dbmate --migrations-dir ./migrations --url $DB_URL down",
    "db:status": "bunx dbmate --migrations-dir ./migrations --url $DB_URL status",
    "db:new": "bunx dbmate --migrations-dir ./migrations new",
    "supabase": "supabase",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "docker:up": "docker compose -f ../../docker/compose.yml up -d",
    "docker:down": "docker compose -f ../../docker/compose.yml down"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.0",
    "@elysiajs/swagger": "^1.3.1",
    "@nats-io/jetstream": "^3.2.0",
    "@nats-io/transport-node": "^3.2.0",
    "@roadmate/shared": "workspace:*",
    "@supabase/supabase-js": "^2.45.0",
    "elysia": "^1.4.13",
    "elysia-rate-limit": "^4.4.2",
    "expo-server-sdk": "^3.10.0",
    "ioredis": "^5.8.1",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.13.1",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/jsonwebtoken": "^9.0.10",
    "bun-types": "latest",
    "dbmate": "^2.0.0",
    "supabase": "^2.23.4",
    "typescript": "~5.7.2"
  }
}
