# Copy to .env (gitignored)

# --- Database (PostGIS) ---
POSTGRES_USER=roadmate
POSTGRES_PASSWORD=roadmate
POSTGRES_DB=roadmate
POSTGRES_PORT=5432
# dbmate / app connection string
DB_URL=postgres://roadmate:roadmate@localhost:5432/roadmate?sslmode=disable

# --- Redis (live location cache) ---
REDIS_URL=redis://localhost:6379

# --- NATS (push fan-out) ---
NATS_URL=nats://localhost:4222

# --- Supabase (auth + storage for profile photos) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth ---
JWT_SECRET=change-me

# --- SMS (phone verification) — Twilio or Infobip ---
SMS_PROVIDER=infobip
SMS_API_KEY=

# --- App ---
PORT=3000
LOG_LEVEL=info
DOCKER_NETWORK=roadmate_network

# Matching defaults
MATCH_RADIUS_M=15000
MATCH_RADIUS_MAX_M=30000
HELPER_STALE_MINUTES=20
